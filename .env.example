# ===========================
# NEXUS-CYBER DATA-VAULT CONFIGURATION
# Copy to .env and fill with your values
# ===========================

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_PORT=3307
DB_USER=ktp_user
DB_PASSWORD=your_strong_password_here
DB_NAME=ktp_database
DB_POOL_SIZE=10

# PROXY CONFIGURATION
PROXY_LISTEN_HOST=0.0.0.0
PROXY_LISTEN_PORT=3306
PROXY_BACKEND_HOST=localhost
PROXY_BACKEND_PORT=3307
PROXY_LOG_FILE=logs/proxy.log

# DETECTION CONFIGURATION
DETECTION_LOG_FILE=logs/detection.log
THREAT_LOG_FILE=logs/threats.log
AUDIT_LOG_FILE=logs/audit.log

# ADMIN AUTHENTICATION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# TELEGRAM ALERTS
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# AI/OLLAMA CONFIGURATION
OLLAMA_HOST=http://localhost:11434
QWEN_MODEL=qwen2.5-coder
LLAMA_MODEL=llama3
AI_TIMEOUT=30

# HARDWARE CONFIGURATION (ASUS specific)
ASUS_RGB_ENABLED=true
ASUS_FAN_CONTROL_ENABLED=true

# LOGGING CONFIGURATION
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_ROTATION_DAYS=30

# ENVIRONMENT
ENVIRONMENT=development
DEBUG=false
