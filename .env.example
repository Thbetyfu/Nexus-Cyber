# ===========================
# NEXUS-CYBER ENVIRONMENT CONFIGURATION
# Copy to .env and fill with your values
# DO NOT commit .env to version control!
# ===========================

# ===========================
# APPLICATION ENVIRONMENT
# ===========================

# Flask configuration
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_SECRET_KEY=generate-a-random-secret-key-here-use-python-secrets

# Application host/port
APP_HOST=0.0.0.0
APP_PORT=5000

# ===========================
# DATABASE CONFIGURATION
# ===========================

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=ktp_user
DB_PASSWORD=your-secure-database-password
DB_NAME=ktp_database
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30

# Database SSL (optional)
DB_SSL_ENABLED=false
DB_SSL_CA=/path/to/ca-cert.pem
DB_SSL_CERT=/path/to/client-cert.pem
DB_SSL_KEY=/path/to/client-key.pem

# ===========================
# PROXY CONFIGURATION
# ===========================

# TCP Proxy settings
PROXY_LISTEN_HOST=0.0.0.0
PROXY_LISTEN_PORT=3306
PROXY_BACKEND_HOST=localhost
PROXY_BACKEND_PORT=3307
PROXY_LOG_FILE=logs/proxy.log
PROXY_TIMEOUT_SECONDS=30

# ===========================
# AUTHENTICATION
# ===========================

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-very-secure-admin-password-min-16-chars
ADMIN_IP_WHITELIST=127.0.0.1,192.168.1.0/24

# Session management
SESSION_TIMEOUT_MINUTES=480
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ===========================
# THREAT DETECTION
# ===========================

# Detection thresholds
DETECTION_CONFIDENCE_THRESHOLD=0.5
DETECTION_RISK_THRESHOLD=50

# Rate limiting
RATE_LIMIT_QUERIES_PER_MINUTE=100
RATE_LIMIT_BYTES_PER_MINUTE=10485760
RATE_LIMIT_ENABLED=true

# IP blocking
ENABLE_IPTABLES=true
BAN_DURATION_HOURS=24
AUTO_UNBLOCK_EXPIRED=true

# ===========================
# AI/OLLAMA CONFIGURATION
# ===========================

# Ollama settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=60

# Models
QWEN_MODEL=qwen2.5-coder
LLAMA_MODEL=llama3

# AI settings
AI_CACHE_ENABLED=true
AI_CACHE_SIZE=1000
AI_FALLBACK_ENABLED=true
AI_TEMPERATURE=0.1

# ===========================
# NOTIFICATIONS
# ===========================

# Telegram alerts
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
TELEGRAM_TIMEOUT=10

# Email alerts (optional)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=nexus-cyber@example.com
EMAIL_RECIPIENTS=admin@example.com,security@example.com

# ===========================
# HARDWARE INTEGRATION (ASUS)
# ===========================

# ASUS RGB control
ASUS_RGB_ENABLED=true
ASUS_FAN_CONTROL_ENABLED=true
ADMIN_PASSWORD_FOR_SUDO=your-admin-password-for-sudo-commands

# ===========================
# LOGGING & MONITORING
# ===========================

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10

# Security logging
SECURITY_LOG_FILE=logs/security.log
AUDIT_LOG_FILE=logs/audit.log

# ===========================
# PERFORMANCE TUNING
# ===========================

# Buffer sizes
PROXY_CHUNK_SIZE_BYTES=65536
QUERY_BUFFER_SIZE=1000
LOG_BUFFER_SIZE=100

# Timeouts
CONNECTION_TIMEOUT=30
QUERY_TIMEOUT=300
API_TIMEOUT=30

# ===========================
# COMPLIANCE & RETENTION
# ===========================

# Data retention
QUERY_LOG_RETENTION_DAYS=90
INCIDENT_LOG_RETENTION_DAYS=365
BLOCKED_IP_RETENTION_DAYS=30

# Compliance
ENABLE_GDPR_MODE=false
ENABLE_PCI_DSS_MODE=false
DATA_ENCRYPTION_ENABLED=false

# ===========================
# DEPLOYMENT
# ===========================

# Environment name
ENVIRONMENT=production
DEPLOYMENT_NAME=nexus-cyber-prod-01
VERSION=1.0.0

# Debug settings
DEBUG=false
VERBOSE=false
DEVELOPMENT_MODE=false

# ===========================
# FEATURE FLAGS
# ===========================

# Enable/disable features
FEATURE_FORENSIC_ANALYSIS=true
FEATURE_HARDWARE_ALERTS=true
FEATURE_TELEGRAM_ALERTS=true
FEATURE_EMAIL_ALERTS=false
FEATURE_AI_DETECTION=true
FEATURE_RULE_DETECTION=true

# ===========================
# SECURITY SETTINGS
# ===========================

# Password policy
MIN_PASSWORD_LENGTH=16
REQUIRE_SPECIAL_CHARS=true
REQUIRE_NUMBERS=true
REQUIRE_UPPERCASE=true

# IP restrictions
ALLOW_LOCALHOST_ONLY=false
ALLOWED_ADMIN_IPS=127.0.0.1,192.168.1.0/24
BLOCK_SUSPICIOUS_ACTIVITY=true

# Rate limiting for login
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:5000
CORS_ALLOW_CREDENTIALS=true
